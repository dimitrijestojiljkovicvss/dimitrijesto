@page
@model IndexModel
@{
    Layout = null;
    ViewData["Title"] = "Home";
}

<link href="https://fonts.googleapis.com/css2?family=Inknut+Antiqua:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inknut Antiqua', serif;
        margin: 0;
        background: white;
        color: black;
    }

    .home-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem;
    }

    .logo-section {
        text-align: center;
        margin-bottom: 1rem;
    }

    .logo img {
        max-width: 450px;
        height: auto;
    }

    .tagline {
        font-style: italic;
        color: #555;
    }

    .main-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 2rem;
        align-items: start;
    }

    .portfolio-preview {
        text-align: center;
    }

        .portfolio-preview img {
            width: 100%;
            height: auto;
            display: block;
            margin-bottom: 0.5rem;
        }

        .portfolio-preview h2 {
            font-size: 1.5rem;
            letter-spacing: 2px;
        }

        .portfolio-preview a {
            color: black;
            text-decoration: none;
        }

    .booking-section h2 {
        background: #ccc;
        padding: 0.5rem;
        text-align: center;
        margin: 0;
        font-size: 1.3rem;
    }

    .booking-text {
        background: #444;
        color: white;
        padding: 1rem;
        margin-top: 0.5rem;
    }

    .about-us {
        background: #eee;
        padding: 1rem;
        margin-top: 1rem;
        text-align: center;
    }

        .about-us h3 {
            margin-bottom: 0.5rem;
        }

    .icons img {
        width: 40px;
        height: auto;
        margin: 0 0.3rem;
        vertical-align: middle;
    }

    .booking-section a {
        color: inherit;
        text-decoration: none;
    }

    .contact-info, .business-hours {
        background: #ddd;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .business-hours {
        background: #333;
        color: white;
    }

    .google-rating {
        text-align: center;
        font-size: 0.9rem;
    }

        .google-rating a {
            color: inherit;
            text-decoration: none;
        }

    .icon {
        width: 20px;
        height: auto;
        vertical-align: middle;
        margin-right: 5px;
    }

    .logo2 {
        position: relative;
        text-align: center;
        margin: 30px auto 60px;
    }

        .logo2 img {
            max-width: 80px;
            height: auto;
        }

        .logo2 .lang-pill {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            left: calc(50% + 400px);
            background: #d9d9d9;
            color: #000;
            padding: 0.4rem 0.8rem;
            border-radius: 12px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }
</style>

<div class="home-container">

    <header class="logo-section">
        <div class="logo">
            <img src="/images/logo.png" alt="Dimistoo Tattoo Logo" />
        </div>
        <p class="tagline">DIMISTOO INK, WHERE THE HEART AND SOUL LINK</p>
    </header>

    <div class="main-grid">

        <div class="portfolio-preview">
            <a href="/Portfolio">
                <img src="/images/portfolio/sample.jpeg" alt="Portfolio Preview" />
                <h2>PORTFOLIO</h2>
            </a>
        </div>

        <div class="booking-section">
            <a href="/Book"><h2>BOOK a TTo</h2></a>
            <div class="booking-text">
                Our studio is set to open in early 2026.<br />
                Stay connected for updates by following us on social media and visiting this website.
            </div>
            <a href="/About">
                <div class="about-us">
                    <h3>About us</h3>
                    <div class="icons">
                        <img src="/images/icons/home.png" alt="Home Icon" />
                        <img src="/images/icons/heart.png" alt="Heart Icon" />
                        <img src="/images/icons/brush.png" alt="Brush Icon" />
                    </div>
                </div>
            </a>
        </div>

        <div class="contact-section">
            <div class="contact-info">
                <p>
                    <img src="/images/icons/phone.png" alt="Phone Icon" class="icon" />
                    +387 70 479 050
                </p>
                <p>
                    <a href="https://www.instagram.com/dimistoo.ink" target="_blank">
                        <img src="/images/icons/instagram.png" alt="Instagram Icon" class="icon" />
                        dimistoo.ink
                    </a>
                </p>
            </div>
            <div class="business-hours">
                <h3>Business Hours</h3>
                <p><strong>Monday – Friday:</strong> 10:00 AM – 6:00 PM</p>
                <p><strong>Saturday:</strong> 11:00 AM – 5:00 PM</p>
                <p><strong>Sunday:</strong> Closed</p>
                <p>Appointments outside business hours available upon request.</p>
            </div>
            <p class="google-rating">
                <a href="https://share.google/ExStdnXLEyg0ERl93" target="_blank">
                    Rate us on Google!
                    <img src="/images/icons/google.png" alt="Google Icon" class="icon" />
                </a>
            </p>
        </div>

    </div>
    <div class="logo2">
        <img src="/images/ds100.png" alt="DS 100 logo" />
        <span class="lang-pill">EN – SLO – SRB</span>
    </div>

</div>
