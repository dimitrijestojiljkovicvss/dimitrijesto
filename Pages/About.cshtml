@page
@model Projekt.Pages.AboutModel
@{
    ViewData["Title"] = "About Me";
}

<link href="https://fonts.googleapis.com/css2?family=Inknut+Antiqua&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inknut Antiqua', serif;
        margin: 0;
        padding: 0;
        background: white;
        color: white;
        text-align: center;
    }

    header {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        padding: 20px;
        background: white;
    }

        header img {
            width: 450px;
            height: auto;
        }

    .cards {
        display: flex;
        justify-content: center;
        gap: 20px;
        padding: 20px;
        flex-wrap: wrap;
    }

    .card {
        background: #5a5a5a;
        padding: 20px;
        border-radius: 5px;
        width: 300px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 350px;
        text-align: left;
        font-family: 'Inknut Antiqua', serif;
    }

        .card img.main {
            max-width: 100%;
            border-radius: 5px;
            margin-bottom: 15px;
        }

        .card p {
            font-size: 0.95em;
            line-height: 1.5em;
        }

    .card-icon {
        margin-top: 15px;
        text-align: center;
    }

        .card-icon img {
            width: 30px;
        }

    footer {
        margin-top: 30px;
    }

        footer img {
            max-width: 80px;
        }

    .logo {
        margin: 30px auto 60px;
        display: block;
        text-align: center;
    }

        .logo img {
            max-width: 80px;
        }
</style>

<header>
    <img src="/images/logo.png" alt="DJ 100 Tattoo Logo" />
</header>

<div class="cards">
    <div class="card">
        <img src="/images/artist2.jpeg" alt="Tattoo Artist" class="main" />
        <p>
            Our studio will be located at Pobreska cesta 13, 2000 Maribor.
            We're always happy to welcome new faces, stop by, say hi, and see what we're creating.
        </p>
        <div class="card-icon">
            <img src="/images/icons/home.png" alt="Home Icon" />
        </div>
    </div>

    <div class="card">
        <p>
            As a thank-you to my incredible community, this entire year will be bursting with excitement —
            from exclusive giveaways and custom tattoos to limited-edition merch, adorable plushies, and unique mascots.
            And that’s just the beginning… there’s so much more on the way to make 2026 unforgettable!
        </p>
        <div class="card-icon">
            <img src="/images/icons/heart.png" alt="Heart Icon" />
        </div>
    </div>

    <div class="card">
        <p>
            You should always get your tattoos from licensed professionals. Proper hygiene isn’t just important, it’s essential.
            A clean, sterile environment protects you from infections, ensures the best healing process,
            and guarantees that your new tattoo will be both safe and beautiful.
            Never compromise your health for a cheaper or faster option.
        </p>
        <div class="card-icon">
            <img src="/images/icons/brush.png" alt="Checkmark Icon" />
        </div>
    </div>
</div>

<div class="logo">
    <img src="/images/ds100.png" alt="DS 100 logo" />
</div>
