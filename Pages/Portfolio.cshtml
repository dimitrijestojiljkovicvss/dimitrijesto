@page
@model Projekt.Pages.PortfolioModel
@{
    ViewData["Title"] = "Portfolio";
}

<link href="https://fonts.googleapis.com/css2?family=Inknut+Antiqua&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inknut Antiqua', serif;
        margin: 0;
        padding: 20px;
        background: white;
        color: black;
        text-align: center;
    }

    .intro {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 40px;
    }

        .intro img {
            max-width: 200px;
            border-radius: 5px;
        }

    .bio {
        max-width: 400px;
        text-align: left;
        font-size: 0.95em;
        font-family: 'Inknut Antiqua', serif;
    }

    .social-icons {
        margin-top: 10px;
        font-size: 1.5em;
    }

    .cat-art {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 400px;
        max-width: none; 
    }

    h1 {
        font-family: 'Inknut Antiqua', serif;
        font-size: 3em;
        margin: 20px 0;
    }

    .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 15px;
        max-width: 800px;
        margin: auto;
    }

        .portfolio-grid img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 5px;
        }

    .logo {
        margin: 30px auto 60px;
        display: block;
        text-align: center;
    }

        .logo img {
            max-width: 80px;
        }
</style>

<div class="intro">
    <img src="/images/artist.jpeg" alt="Tattoo artist" />
    <div class="bio">
        <p>
            I'm a young tattoo artist, driven by ambition and fueled by motivation.
            My purpose is to give you more than just a tattoo. I want to create the perfect piece for you and make the entire experience unforgettable.
            Will you be my canvas on this journey to mastering the art of ink?
        </p>
        <div class="social-icons">
            <a href="#"><img src="/images//icons/tiktok.png" alt="TikTok" width="24"></a>
            <a href="https://www.instagram.com/dimistoo.ink"><img src="/images/icons/instagram.png" alt="Instagram" width="24"></a>
        </div>
    </div>
</div>

<img src="/images/cat2.png" alt="cat art" class="cat-art" />

<h1>PORTFOLIO</h1>

<div class="portfolio-grid">
    <img src="/images/tattoo1.jpeg" alt="tattoo">
    <img src="/images/tattoo2.jpeg" alt="tattoo">
    <img src="/images/tattoo3.jpeg" alt="tattoo">
    <img src="/images/tattoo4.jpeg" alt="tattoo">
    <img src="/images/tattoo5.jpeg" alt="tattoo">
    <img src="/images/tattoo6.jpeg" alt="tattoo">
    <img src="/images/tattoo7.jpeg" alt="tattoo">
    <img src="/images/tattoo8.jpeg" alt="tattoo">
</div>

<div class="logo">
    <img src="/images/ds100.png" alt="DS 100 logo" />
</div>
